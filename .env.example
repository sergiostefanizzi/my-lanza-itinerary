# Configurazione Supabase per l'autenticazione.
# Copia questo file in `.env` (gitignored) e imposta gli stessi valori anche su
# Vercel: Project -> Settings -> Environment Variables.
#
# Le nuove API keys di Supabase (consigliate, sostituiscono anon/service_role):
#   Settings -> API Keys  ->  Publishable key (sb_publishable_...) e Secret key (sb_secret_...)

# --- Pubbliche: esposte al client (prefisso VITE_), sicure da pubblicare ---
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx

# --- Solo server (funzione /api): NON esporre, NIENTE prefisso VITE_ ---
# Se trapela, rigenera/revoca questa singola chiave dalla dashboard Supabase.
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxx

# Numero massimo di utenti che possono registrarsi. Cambialo su Vercel per
# alzare/abbassare il tetto senza toccare il codice.
MAX_USERS=4
